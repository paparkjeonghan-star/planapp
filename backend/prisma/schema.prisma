generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String
  createdAt DateTime @default(now())
}

model Student {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  school    String?
  grade     String?
  scores    String?
  notes     String?
  subjects  Subject[]
  timetables Timetable[]
  plans     Plan[]
  examSchedule ExamSchedule?
}

model ExamSchedule {
  id        String   @id @default(uuid())
  studentId String   @unique
  midterm1  DateTime?
  final1    DateTime?
  midterm2  DateTime?
  final2    DateTime?
  updatedAt DateTime @updatedAt

  student   Student  @relation(fields: [studentId], references: [id])
}

model Subject {
  id               String   @id @default(uuid())
  studentId        String?
  name             String
  weeklyTargetHours Float    @default(0)
  priority         Int      @default(0)
  color            String?

  student          Student? @relation(fields: [studentId], references: [id])
  slots            Slot[]
  allocations      Allocation[]
  sessions         StudySession[]
}

model Timetable {
  id        String @id @default(uuid())
  studentId String
  weekStart DateTime
  slots     Slot[]

  student   Student @relation(fields: [studentId], references: [id])
}

model Slot {
  id          String @id @default(uuid())
  timetableId String
  dayOfWeek   Int
  startTime   String
  endTime     String
  type        String
  subjectId   String?
  category    String?
  studyType   String?
  notes       String?
  completed   Boolean @default(false)

  timetable   Timetable @relation(fields: [timetableId], references: [id])
  subject     Subject?  @relation(fields: [subjectId], references: [id])
}

model Plan {
  id            String         @id @default(uuid())
  studentId     String
  weekStart     DateTime
  generatedAt   DateTime       @default(now())
  autoGenerated Boolean        @default(true)
  allocations   Allocation[]
  sessions      StudySession[]

  student       Student        @relation(fields: [studentId], references: [id])
}

model Allocation {
  id        String  @id @default(uuid())
  planId    String
  subjectId String
  hours     Float
  sessions  Int

  plan      Plan    @relation(fields: [planId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])
}

model StudySession {
  id              String  @id @default(uuid())
  planId          String
  subjectId       String
  date            DateTime
  startTime       String
  durationMinutes Int
  completed       Boolean @default(false)
  notes           String?

  plan            Plan    @relation(fields: [planId], references: [id])
  subject         Subject @relation(fields: [subjectId], references: [id])
}

model Template {
  id        String @id @default(uuid())
  name      String
  structure String
}
